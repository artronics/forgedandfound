{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "build/**"],
      "inputs": ["$TURBO_DEFAULT$", ".env.local", ".env.development"],
      "env": ["NEXT_PUBLIC_SHOPIFY_STORE_NAME", "NEXT_PUBLIC_SHOPIFY_STOREFRONT_PUBLIC_TOKEN"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "codegen": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
