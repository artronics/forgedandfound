# Copy to .env.development and fill in. Next.js loads env files from THIS
# directory (apps/web), never the repo root.
#
# Env layering for local `next dev`:
#   .env.development        <- these NON-PLATFORM values (commit-free, stable)
#   .env.development.local  <- PLATFORM values, generated by `task deploy:web:dev`
#                              (Cognito client + API URL for your deployment)
# .local always wins. Both are gitignored.
#
# `next build` (production, e.g. on Vercel) does NOT read .env.development* —
# there the values come from the Vercel project's env vars + --build-env.

# --- Shopify (non-platform) ---
NEXT_PUBLIC_SHOPIFY_STORE_NAME=
NEXT_PUBLIC_SHOPIFY_STOREFRONT_PUBLIC_TOKEN=
NEXT_PUBLIC_SHOPIFY_API_VERSION=2026-01
# Optional: proxy domain instead of <store>.myshopify.com
# NEXT_PUBLIC_SHOPIFY_STOREFRONT_URL=
SHOPIFY_ADMIN_CLIENT_ID=
SHOPIFY_ADMIN_CLIENT_SECRET=

# --- App (non-platform) ---
AUTH_SECRET=
PLACEHOLDER_EMAIL_DOMAIN=no-reply.nonprod.forgedandfound.co.uk
# NEXT_PUBLIC_GTM_ID=
